# =============================================================================
# Roavaa — environment variables (TEMPLATE)
# =============================================================================
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` or any real secret to Git.
#
# Phase 0 note:
#   The app INSTALLS, TYPECHECKS, TESTS and BUILDS with NO real values here.
#   Supabase and the AI provider are wired at the code level but not called yet,
#   so none of the variables below are required to run Phase 0 locally.
# =============================================================================

# --- Public app config (safe to expose to the browser) ----------------------
# Public brand name shown in the UI (Roavaa = Repond. Organise. Apprend.).
NEXT_PUBLIC_APP_NAME="Roavaa"

# Canonical public URL, used in metadata (canonical tags, sitemap, robots,
# OG/Twitter images). Defaults to the current Vercel production URL if unset;
# set this once a custom domain is live.
# NEXT_PUBLIC_SITE_URL="https://roavaa.com"

# --- Supabase (Phase 1) -----------------------------------------------------
# Public values: safe in the browser, protected by Row Level Security.
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# SERVER ONLY. Never prefix with NEXT_PUBLIC_. Never import in a client
# component. Bypasses Row Level Security — treat like a master password.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret-key"

# --- AI provider ------------------------------------------------------------
# Defaults to the offline MockAIProvider (no network, no key needed).
# To use the real, vision-capable Anthropic provider: set AI_PROVIDER=anthropic
# and ANTHROPIC_API_KEY below. Needs a funded Anthropic Console account
# (https://console.anthropic.com/settings/keys) — API calls fail with a 400
# "credit balance too low" until credits/billing are set up there.
# Supported: "mock" (default) | "anthropic"
AI_PROVIDER="mock"
# ANTHROPIC_API_KEY=""

# Email sending (Resend). Without these, no email is sent (app still works).
RESEND_API_KEY=
EMAIL_FROM="Roavaa <onboarding@resend.dev>"

# --- Billing (Stripe) --------------------------------------------------------
# Entirely optional. Without STRIPE_SECRET_KEY, the app runs exactly as today:
# prices are shown, the 30-day free trial still works, no card is collected,
# no charge is ever attempted, and every "subscribe" button redirects back
# with a clear "activation in progress" message instead of erroring.
#
# Once Stripe finishes verifying the account: create one Product with 3
# monthly Prices (Starter 49, Professional 99, Enterprise 199) in EUR, add
# their IDs below, set STRIPE_SECRET_KEY, and turn on the webhook — nothing
# else in the code needs to change.
STRIPE_SECRET_KEY=
# Signing secret of the webhook endpoint configured in the Stripe dashboard,
# pointing at POST {NEXT_PUBLIC_SITE_URL}/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_PROFESSIONAL_MONTHLY=
STRIPE_PRICE_ENTERPRISE_MONTHLY=
# Reserved for a future annual license — read the moment they're set, no code change needed.
# STRIPE_PRICE_STARTER_YEARLY=
# STRIPE_PRICE_PROFESSIONAL_YEARLY=
# STRIPE_PRICE_ENTERPRISE_YEARLY=

# Shared secret Vercel Cron sends as `Authorization: Bearer <value>` when it
# calls /api/cron/billing-reminders. Optional locally; set it in Vercel once
# the cron is live so the endpoint can't be triggered by anyone else.
CRON_SECRET=

# --- Platform owner (Super Admin) --------------------------------------------
# The one ROAVAA account that gets full, free, unlimited access to every
# organization it belongs to — never billed, never suspended. Must match the
# exact verified email of that Supabase auth user.
PLATFORM_OWNER_EMAIL=

# --- RDW open data (license-plate lookup) -----------------------------------
# Vehicle technical data (make, model, year, fuel, colour, MOT) is fetched from
# the RDW open-data API when a mechanic types a plate. The API is FREE and works
# WITHOUT a token; an App Token only raises the per-hour rate limit. Optional.
# Get one free at https://opendata.rdw.nl (Sign up → App Tokens).
RDW_APP_TOKEN=
