# =============================================================================
# Roavaa — environment variables (TEMPLATE)
# =============================================================================
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` or any real secret to Git.
#
# Phase 0 note:
#   The app INSTALLS, TYPECHECKS, TESTS and BUILDS with NO real values here.
#   Supabase and the AI provider are wired at the code level but not called yet,
#   so none of the variables below are required to run Phase 0 locally.
# =============================================================================

# --- Public app config (safe to expose to the browser) ----------------------
# Public brand name shown in the UI (Roavaa = Repond. Organise. Apprend.).
NEXT_PUBLIC_APP_NAME="Roavaa"

# Canonical public URL, used in metadata (canonical tags, sitemap, robots,
# OG/Twitter images). Defaults to the current Vercel production URL if unset;
# set this once a custom domain is live.
# NEXT_PUBLIC_SITE_URL="https://roavaa.com"

# --- Supabase (Phase 1) -----------------------------------------------------
# Public values: safe in the browser, protected by Row Level Security.
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# SERVER ONLY. Never prefix with NEXT_PUBLIC_. Never import in a client
# component. Bypasses Row Level Security — treat like a master password.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret-key"

# --- AI provider (Phase 1) --------------------------------------------------
# Phase 0 ships ONLY a MockAIProvider (no network, no key needed).
# When a real provider is added later, select it here and add its key.
# Supported later: "mock" (default) | "anthropic" | "openai"
AI_PROVIDER="mock"
# ANTHROPIC_API_KEY=""
# OPENAI_API_KEY=""

# Email sending (Resend). Without these, no email is sent (app still works).
RESEND_API_KEY=
EMAIL_FROM="Roavaa <onboarding@resend.dev>"
